<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <record id="email_template_phieu_luong" model="mail.template">
      <field name="name">Phiếu lương - Gửi cho nhân viên</field>
      <field name="email_from">${(user.company_id and user.company_id.email) or 'no-reply@example.com'}</field>
      <field name="subject">[Phiếu lương] ${object.name or ''} - ${object.thang}/${object.nam}</field>
      <field name="model_id" ref="tinh_luong.model_phieu_luong"/>
      <field name="auto_delete" eval="True"/>
      <field name="body_html"><![CDATA[
        <p>Xin chào ${object.nhan_vien_id.ho_va_ten or ''},</p>
        <p>Đây là phiếu lương tháng ${object.thang}/${object.nam}.</p>
        <p>Tổng thu nhập: <strong>${object.tong_luong}</strong></p>
        <p>Chi tiết có trong hệ thống. Trân trọng.</p>
      ]]></field>
    </record>
  </data>
</odoo>
