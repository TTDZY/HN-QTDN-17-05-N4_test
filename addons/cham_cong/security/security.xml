<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_cham_cong_self" model="ir.rule">
        <field name="name">Nhân viên xem chấm công của mình</field>
        <field name="model_id" ref="model_cham_cong"/>
        <field name="domain_force">[('nhan_vien_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="rule_cham_cong_hr_all" model="ir.rule">
        <field name="name">HR xem toàn bộ chấm công</field>
        <field name="model_id" ref="model_cham_cong"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_user'))]"/>
    </record>
    <record id="rule_dashboard_cham_cong_self" model="ir.rule">
        <field name="name">Nhân viên xem dashboard chấm công của mình</field>
        <field name="model_id" ref="model_dashboard_cham_cong"/>
        <field name="domain_force">[('nhan_vien_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="rule_dashboard_cham_cong_hr_all" model="ir.rule">
        <field name="name">HR xem toàn bộ dashboard chấm công</field>
        <field name="model_id" ref="model_dashboard_cham_cong"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_user'))]"/>
    </record>
    <record id="rule_don_tu_self" model="ir.rule">
        <field name="name">Nhân viên quản lý đơn của mình</field>
        <field name="model_id" ref="model_don_tu"/>
        <field name="domain_force">[('nhan_vien_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="rule_don_tu_hr_all" model="ir.rule">
        <field name="name">HR xem toàn bộ đơn từ</field>
        <field name="model_id" ref="model_don_tu"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_user'))]"/>
    </record>
</odoo>
